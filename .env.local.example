# ─── Clé API Anthropic (obligatoire) ───────────────────────────────────────
# À créer sur https://console.anthropic.com/
# Copie ce fichier en `.env.local` puis colle ta clé ci-dessous.
ANTHROPIC_API_KEY=

# ─── Authentification (déploiement en ligne) ───────────────────────────────
# Mot de passe d'accès à l'app. OBLIGATOIRE en production (sinon l'app renvoie 503).
# En local, si vide, l'accès reste libre.
APP_PASSWORD=
# Identifiant (facultatif, défaut : "solar"). Au login, saisis cet identifiant + le mot de passe.
APP_USER=

# ─── Stockage (déploiement en ligne) ───────────────────────────────────────
# Dossier où sont écrites les données (interventions, fiches, docs, procédures).
# En local : laisser vide → `./data`.
# Sur Railway : pointe vers le volume persistant, ex. /data
DATA_DIR=
